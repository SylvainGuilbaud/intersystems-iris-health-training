# prod_utils.sh configuration

# Local Docker container name
DOCKER_CONTAINER=iris-health-training-dev

# AWS Development environment
AWS_DEV_HOST=your-dev-instance.amazonaws.com
AWS_DEV_USER=ubuntu

# AWS Production environment
AWS_PROD_HOST=your-prod-instance.amazonaws.com
AWS_PROD_USER=ubuntu

# IRIS code path in container
IRIS_CODE_PATH=/code/adm/utils.py
